{
  "info": {
    "name": "Blueprint Chat API Public",
    "description": "API publik untuk fitur chat blueprint.\n\nBase URL: http://localhost:3000\n\n## Cara pakai:\n1. Cukup kirim `baId` dan `message` saja — senderId otomatis terisi PM dari project team\n2. File bisa diupload via FormData\n3. `senderId` optional — hanya jika ingin override (pakai user tertentu)\n\n## Cek daftar BA:\nGET /api/public/blueprint-chat?baId={id}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET Messages",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/public/blueprint-chat?baId={{baId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "public", "blueprint-chat"],
          "query": [
            {
              "key": "baId",
              "value": "{{baId}}",
              "description": "ID BA (Bacara) — lihat dari URL blueprint-baru/{id}"
            }
          ]
        }
      }
    },
    {
      "name": "POST Send Message (JSON - auto sender PM)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"baId\": {{baId}},\n  \"message\": \"Ini pesan otomatis dari API publik\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/public/blueprint-chat",
          "host": ["{{base_url}}"],
          "path": ["api", "public", "blueprint-chat"]
        },
        "description": "senderId otomatis terisi dari PM pertama di proyek_team project ini."
      }
    },
    {
      "name": "POST Send Message (JSON - override senderId)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"baId\": {{baId}},\n  \"senderId\": {{senderId}},\n  \"message\": \"Pesan dengan sender manual\",\n  \"fileUrl\": \"https://example.com/file.pdf\",\n  \"fileName\": \"dokumen.pdf\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/public/blueprint-chat",
          "host": ["{{base_url}}"],
          "path": ["api", "public", "blueprint-chat"]
        },
        "description": "Override senderId jika ingin pakai user tertentu (bukan PM otomatis)."
      }
    },
    {
      "name": "POST Send Message (FormData - upload file)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "baId",
              "value": "{{baId}}",
              "type": "text"
            },
            {
              "key": "message",
              "value": "Pesan dengan file attachment",
              "type": "text"
            },
            {
              "key": "file",
              "type": "file",
              "src": "",
              "description": "Pilih file dari komputer"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/public/blueprint-chat",
          "host": ["{{base_url}}"],
          "path": ["api", "public", "blueprint-chat"]
        },
        "description": "Upload file langsung — senderId otomatis dari PM project team."
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Base URL aplikasi"
    },
    {
      "key": "baId",
      "value": "14",
      "type": "string",
      "description": "ID BA — lihat dari URL blueprint-baru/{id}"
    },
    {
      "key": "senderId",
      "value": "1",
      "type": "string",
      "description": "Optional — hanya dipakai untuk override sender (biasanya auto dari PM)"
    }
  ]
}
