									"        console.log(\"Total KPI:\", jsonData.data.kpi.totalPercentage + \"%\");",
									"        console.log(\"Total Tasks:\", jsonData.data.metrics.totalTasklist);",
									"    }",
									"} else if (pm.response.code === 403) {",
