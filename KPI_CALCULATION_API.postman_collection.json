			"item": [
				{
					"name": "Login - Get Session Cookie",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Session cookie will be automatically saved by Postman",
									"if (pm.response.code === 200) {",
									"    console.log(\"✅ Login successful, session cookie saved\");",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.user) {",
									"        console.log(\"User:\", jsonData.user.namaLengkap);",
									"        console.log(\"Role:\", jsonData.user.role);",
									"    }",
									"} else {",
									"    console.log(\"❌ Login failed\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"your_username\",\n  \"password\": \"your_password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						},
						"description": "Login untuk mendapatkan session cookie. Cookie akan otomatis disimpan oleh Postman dan digunakan untuk request selanjutnya."
					},
					"response": []
				},
