		{
			"name": "KPI Calculation",
			"item": [
				{
					"name": "Get My KPI - Current User (Default 30 Days)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.success) {",
									"        console.log(\"✅ KPI Data Retrieved\");",
									"        console.log(\"Programmer:\", jsonData.data.programmer.name);",
									"        console.log(\"Total KPI:\", jsonData.data.kpi.totalPercentage + \"%\");",
									"        console.log(\"Period:\", jsonData.data.period.startDate, \"to\", jsonData.data.period.endDate);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/external/kpi-calculation",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"external",
								"kpi-calculation"
							]
						},
						"description": "Mendapatkan KPI untuk user yang sedang login (default: 30 hari terakhir). Session cookie otomatis digunakan."
					},
					"response": []
				},
				{
					"name": "Get My KPI - Custom Date Range",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.success) {",
									"        console.log(\"✅ KPI Data Retrieved\");",
									"        console.log(\"Total KPI:\", jsonData.data.kpi.totalPercentage + \"%\");",
									"        console.log(\"Task Selesai:\", jsonData.data.kpi.taskSelesai.percentage + \"% → contribution:\", jsonData.data.kpi.taskSelesai.contribution);",
									"        console.log(\"Task Tepat Waktu:\", jsonData.data.kpi.taskTepatWaktu.percentage + \"% → contribution:\", jsonData.data.kpi.taskTepatWaktu.contribution);",
									"        console.log(\"Waktu Pengerjaan:\", jsonData.data.kpi.waktuPengerjaan.percentage + \"% → contribution:\", jsonData.data.kpi.waktuPengerjaan.contribution);",
									"        console.log(\"Task Revisi:\", jsonData.data.kpi.taskRevisi.percentage + \"% → contribution:\", jsonData.data.kpi.taskRevisi.contribution);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
