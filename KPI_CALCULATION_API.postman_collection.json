		{
			"name": "Team KPI (PM & Super Admin)",
			"item": [
				{
					"name": "Get All Programmers (Super Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.items) {",
									"        var programmers = jsonData.items.filter(p => p.role === 'PROGRAMMER');",
									"        console.log(\"✅ Found\", programmers.length, \"programmers\");",
									"        programmers.slice(0, 5).forEach(p => {",
									"            console.log(\"-\", p.namaLengkap, \"(ID:\", p.id + \")\");",
									"        });",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
