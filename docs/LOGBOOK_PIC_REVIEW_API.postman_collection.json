{
  "info": {
    "name": "Logbook to PIC Review Integration API",
    "description": "API collection for triggering PIC review requests from the Logbook system when tasks are completed.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "12345678"
  },
  "item": [
    {
      "name": "Request PIC Review",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has success field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('success');",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "pm.test(\"Response contains ticket data\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('ticket');",
              "    pm.expect(jsonData.ticket).to.have.property('id');",
              "    pm.expect(jsonData.ticket).to.have.property('status');",
              "    pm.expect(jsonData.ticket).to.have.property('dispositionStatus');",
              "});",
              "",
              "pm.test(\"Ticket status is WAITING_FOR_CUSTOMER\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.ticket.status).to.eql('WAITING_FOR_CUSTOMER');",
              "});",
              "",
              "pm.test(\"Disposition status is NEEDS_PIC_APPROVAL\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.ticket.dispositionStatus).to.eql('NEEDS_PIC_APPROVAL');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"logbookTaskId\": \"{{logbook_task_id}}\",\n  \"completedBy\": \"{{completed_by}}\",\n  \"completionNotes\": \"{{completion_notes}}\",\n  \"apiKey\": \"{{api_key}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/tickets/{{ticket_id}}/request-pic-review",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "tickets",
            "{{ticket_id}}",
            "request-pic-review"
          ]
        },
        "description": "Triggers a PIC review request for a ticket when a Logbook task is completed.\n\n**Required Fields:**\n- `logbookTaskId`: ID of the completed task in Logbook\n- `apiKey`: Authentication key for Logbook system\n\n**Optional Fields:**\n- `completedBy`: Name of person who completed the task\n- `completionNotes`: Additional notes about completion"
      },
