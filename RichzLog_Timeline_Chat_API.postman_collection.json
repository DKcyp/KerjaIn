              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/richzlog/tasklist/{{tasklist_id}}/timeline?page=1&size=20&sortDir=desc",
              "host": ["{{base_url}}"],
              "path": ["api", "richzlog", "tasklist", "{{tasklist_id}}", "timeline"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "size",
                  "value": "20",
                  "description": "Items per page (default: 20, max: 100)"
                },
                {
                  "key": "sortDir",
                  "value": "desc",
                  "description": "Sort direction: asc or desc (default: desc)"
                }
              ]
            },
            "description": "Get activity timeline for a specific tasklist. Returns paginated list of activities with user information."
          },
