              "body": "{\n  \"success\": true,\n  \"message\": \"Timeline retrieved successfully\",\n  \"data\": {\n    \"items\": [\n      {\n        \"id\": 1,\n        \"tasklistId\": 1,\n        \"activityType\": \"status_change\",\n        \"activityCode\": \"WORK_STARTED\",\n        \"title\": \"Work Started\",\n        \"description\": \"Task work has been started\",\n        \"icon\": \"play_circle\",\n        \"color\": \"#1976D2\",\n        \"userId\": 1,\n        \"userName\": \"John Doe\",\n        \"userPhoto\": null,\n        \"metadata\": {\n          \"oldStatus\": null,\n          \"newStatus\": \"SEDANG_DIPROSES_USER\",\n          \"additionalInfo\": \"Started working\"\n        },\n        \"createdAt\": \"2024-03-28T10:30:00.000Z\",\n        \"formattedTime\": \"10:30\"\n      }\n    ],\n    \"pagination\": {\n      \"page\": 1,\n      \"size\": 20,\n      \"total\": 1,\n      \"totalPages\": 1,\n      \"hasNextPage\": false,\n      \"hasPrevPage\": false\n    }\n  }\n}"
