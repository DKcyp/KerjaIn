  "item": [
    {
      "name": "POST /api/external/tasklist",
      "description": "General external tasklist creation. Requires X-API-Key header.",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{externalApiKey}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/external/tasklist",
          "host": ["{{baseUrl}}"],
          "path": ["api", "external", "tasklist"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"projectCode\": \"PRJ001\",\n  \"moduleCode\": \"01.01\",\n  \"assigneeUsername\": \"johndoe\",\n  \"scheduleAt\": \"2026-06-23T10:00:00.000Z\",\n  \"description\": \"Task description\",\n  \"tasklistType\": \"DEVELOPMENT\",\n  \"taskComplexity\": \"MEDIUM\",\n  \"ticketId\": \"TICKET-001\",\n  \"priority\": \"HIGH\",\n  \"ticketUrl\": \"https://crm.example.com/ticket/001\"\n}"
        }
