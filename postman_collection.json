          "raw": "{\n  \"projectCode\": \"PRJ001\",\n  \"moduleCode\": \"01.01\",\n  \"assigneeUsername\": \"johndoe\",\n  \"scheduleAt\": \"2026-06-23T10:00:00.000Z\",\n  \"description\": \"Task description\",\n  \"ticketId\": \"TICKET-001\",\n  \"ticketUrl\": \"https://crm.example.com/ticket/001\",\n  \"crmId\": \"CRM-456\",\n  \"priority\": \"MEDIUM\",\n  \"tasklistType\": \"DEVELOPMENT\"\n}"
