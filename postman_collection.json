          "body": "{\n  \"success\": true,\n  \"message\": \"Task created successfully\",\n  \"data\": {\n    \"task\": {\n      \"id\": 1234,\n      \"code\": \"26-VI-2301\",\n      \"description\": \"Task description\",\n      \"status\": \"Sedang di proses\",\n      \"originalStatus\": \"MENUNGGU_PROSES_USER\",\n      \"statusCode\": 1,\n      \"scheduleAt\": \"2026-06-23T10:00:00.000Z\",\n      \"tasklistType\": \"DEVELOPMENT\",\n      \"taskComplexity\": \"MEDIUM\",\n      \"projectId\": 1,\n      \"projectName\": \"Project Name\",\n      \"moduleId\": 10,\n      \"moduleName\": \"Module Name\",\n      \"project\": {\n        \"id\": 1,\n        \"code\": \"PRJ001\",\n        \"name\": \"Project Name\"\n      },\n      \"module\": {\n        \"id\": 10,\n        \"code\": \"01.01\",\n        \"name\": \"Module Name\"\n      }\n    }\n  }\n}",
          "code": 201,
          "header": []
        }
      ]
    },
    {
