{
  "info": {
    "name": "RichzLog User Activity API",
    "description": "API untuk mendapatkan ringkasan aktivitas harian user di RichzLog",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get User Daily Activity",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has success field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('success');",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "pm.test(\"Response has data object\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('data');",
              "    pm.expect(jsonData.data).to.have.property('user');",
              "    pm.expect(jsonData.data).to.have.property('date');",
              "    pm.expect(jsonData.data).to.have.property('summary');",
              "    pm.expect(jsonData.data).to.have.property('activities');",
              "    pm.expect(jsonData.data).to.have.property('statistics');",
              "});",
              "",
              "pm.test(\"Summary is a string\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.summary).to.be.a('string');",
              "});",
              "",
              "pm.test(\"Activities is an array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.activities).to.be.an('array');",
              "});",
              "",
              "// Log summary untuk melihat hasil",
              "console.log(\"\\n\" + pm.response.json().data.summary);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/user-activity/daily?userId={{user_id}}&date={{date}}",
          "host": ["{{base_url}}"],
          "path": ["api", "user-activity", "daily"],
          "query": [
            {
              "key": "userId",
              "value": "{{user_id}}",
              "description": "ID user yang ingin dilihat aktivitasnya"
            },
            {
              "key": "date",
              "value": "{{date}}",
              "description": "Tanggal dalam format YYYY-MM-DD"
            }
          ]
        },
        "description": "Mendapatkan ringkasan aktivitas user pada hari tertentu.\n\nParameter:\n- userId: ID user (required)\n- date: Tanggal format YYYY-MM-DD (required)\n\nResponse berisi:\n- Summary text yang sudah diformat\n- Array detail aktivitas per task\n- Statistik total"
      },
